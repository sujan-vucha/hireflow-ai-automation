# Reed official Jobseeker API key
REED_API_KEY=your_reed_api_key_here

# Reed search defaults
REED_KEYWORDS=Digital Marketing Consultant
REED_LOCATION=United Kingdom
REED_LIMIT=1000

# Free local AI expansion/scoring with Ollama
LOCAL_AI_PROVIDER=ollama
OLLAMA_MODEL=qwen3:8b
OLLAMA_BASE_URL=http://127.0.0.1:11434
AI_EXPAND_DEFAULT=true
MAX_EXPANDED_TITLES=20
MIN_RELEVANCE_SCORE=60

# Optional placeholder for future hosted scraper/Apify integration.
# Current scraper still uses local public-page Playwright/Cheerio adapters.
APIFY_TOKEN=your_apify_token_here
